<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/session_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/pf_session_item_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="2dp">

    <!-- Status indicator dot -->
    <View
        android:id="@+id/session_status_indicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/pf_status_running" />

    <!-- Session info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/session_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:textColor="#FFE6EDF3"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/session_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="#FF8B949E"
            android:textSize="11sp"
            android:layout_marginTop="1dp" />

    </LinearLayout>

    <!-- Session number badge -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/session_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="#FF6E7681"
        android:textSize="11sp" />

</LinearLayout>
