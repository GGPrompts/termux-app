<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/activity_termux_root_relative_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="3dp"
        android:layout_marginVertical="0dp"
        android:orientation="vertical">

        <androidx.drawerlayout.widget.DrawerLayout
            android:id="@+id/drawer_layout"
            android:layout_width="match_parent"
            android:layout_alignParentTop="true"
            android:layout_above="@+id/terminal_toolbar_view_pager"
            android:layout_height="match_parent">

            <!-- FrameLayout holds both terminal views; only one visible at a time -->
            <FrameLayout
                android:id="@+id/terminal_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.termux.view.TerminalView
                    android:id="@+id/terminal_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:defaultFocusHighlightEnabled="false"
                    android:focusableInTouchMode="true"
                    android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                    android:scrollbars="vertical"
                    tools:ignore="UnusedAttribute" />

                <!-- GPU terminal renderer (initially hidden; toggle for testing) -->
                <com.termux.app.codefactory.CodefactorySurfaceView
                    android:id="@+id/codefactory_surface_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- PocketForge Navigation Drawer -->
            <LinearLayout
                android:id="@+id/left_drawer"
                android:layout_width="280dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:orientation="vertical"
                android:background="@color/pf_bg_primary"
                android:descendantFocusability="blocksDescendants">

                <!-- Drawer Header / Branding -->
                <LinearLayout
                    android:id="@+id/drawer_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="12dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/drawer_app_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/drawer_app_name"
                        android:textColor="@color/pf_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/drawer_current_floor_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/pf_text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Dashboard quick-launch button -->
                <LinearLayout
                    android:id="@+id/drawer_dashboard_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/pf_settings_item_background"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_dashboard"
                        android:importantForAccessibility="no" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="@string/drawer_dashboard"
                        android:textColor="@color/pf_accent"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":3001"
                        android:textColor="@color/pf_text_muted"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/pf_bg_tertiary" />

                <!-- Tab bar: Terminals | Floors | Settings -->
                <LinearLayout
                    android:id="@+id/drawer_tab_bar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="8dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tab_terminals"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/drawer_tab_terminals"
                        android:textColor="@color/pf_accent"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tab_floors"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/drawer_tab_floors"
                        android:textColor="@color/pf_text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tab_settings"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/drawer_tab_settings"
                        android:textColor="@color/pf_text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Tab indicator line -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginHorizontal="8dp">

                    <View
                        android:id="@+id/tab_indicator"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/pf_tab_indicator" />
                </FrameLayout>

                <!-- Content area: switched by tabs -->
                <FrameLayout
                    android:id="@+id/drawer_content_area"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <!-- TERMINALS TAB: Session list for current floor -->
                    <LinearLayout
                        android:id="@+id/panel_terminals"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <ListView
                            android:id="@+id/terminal_sessions_list"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:divider="@android:color/transparent"
                            android:dividerHeight="0dp"
                            android:choiceMode="singleChoice"
                            android:longClickable="true"
                            android:paddingTop="4dp"
                            android:clipToPadding="false" />

                        <!-- Action buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/new_session_button"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/pf_button_primary"
                                android:text="@string/drawer_new_session"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:backgroundTint="@null" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/toggle_keyboard_button"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:background="@drawable/pf_button_secondary"
                                android:text="@string/action_toggle_soft_keyboard"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:backgroundTint="@null" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- FLOORS TAB: Floor list -->
                    <LinearLayout
                        android:id="@+id/panel_floors"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <ListView
                            android:id="@+id/floor_list"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:divider="@android:color/transparent"
                            android:dividerHeight="0dp"
                            android:choiceMode="singleChoice"
                            android:longClickable="true"
                            android:paddingTop="4dp"
                            android:clipToPadding="false" />

                        <!-- Add floor button -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/add_floor_button"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/pf_button_secondary"
                                android:text="@string/drawer_add_floor"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:backgroundTint="@null" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- SETTINGS TAB: Quick settings -->
                    <ScrollView
                        android:id="@+id/panel_settings"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp">

                            <!-- Settings section header -->
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="4dp"
                                android:text="@string/drawer_settings_appearance"
                                android:textColor="@color/pf_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_theme"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_theme"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_font_size"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_font_size"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_extra_keys"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_extra_keys"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="8dp"
                                android:background="@color/pf_bg_tertiary" />

                            <!-- Terminal section -->
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="4dp"
                                android:text="@string/drawer_settings_terminal"
                                android:textColor="@color/pf_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_keep_screen_on"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_keep_screen_on"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_toggle_toolbar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_toggle_toolbar"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="8dp"
                                android:background="@color/pf_bg_tertiary" />

                            <!-- Advanced section -->
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="4dp"
                                android:text="@string/drawer_settings_advanced"
                                android:textColor="@color/pf_text_secondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_full_settings"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_all_settings"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/settings_gpu_renderer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="48dp"
                                android:gravity="center_vertical"
                                android:background="@drawable/pf_settings_item_background"
                                android:paddingHorizontal="12dp"
                                android:text="@string/drawer_settings_gpu_renderer"
                                android:textColor="@color/pf_text_primary"
                                android:textSize="14sp" />

                        </LinearLayout>
                    </ScrollView>

                </FrameLayout>

            </LinearLayout>

        </androidx.drawerlayout.widget.DrawerLayout>

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/terminal_toolbar_view_pager"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="37.5dp"
            android:background="@color/black"
            android:layout_alignParentBottom="true" />

    </RelativeLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent" />

</com.termux.app.terminal.TermuxActivityRootView>
